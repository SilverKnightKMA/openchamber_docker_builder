{
  "name": "openchamber-docker-builder-toolchain",
  "private": true,
  "description": "Pinned npm toolchain packages baked into the OpenChamber Docker builder image.",
  "license": "MIT",
  "scripts": {
    "validate:release-tools": "node scripts/validate-release-tools.mjs",
    "managed:init": "node scripts/managed-tools.mjs init",
    "managed:update": "node scripts/managed-tools.mjs update",
    "managed:status": "node scripts/managed-tools-status.mjs",
    "managed:npm:install": "node scripts/install-managed-npm-tools.mjs install",
    "managed:npm:status": "node scripts/install-managed-npm-tools.mjs status",
    "managed:go:install": "node scripts/install-managed-go-tools.mjs install",
    "managed:go:status": "node scripts/install-managed-go-tools.mjs status",
    "managed:release-binaries:install": "node scripts/install-managed-release-binaries.mjs install",
    "managed:release-binaries:status": "node scripts/install-managed-release-binaries.mjs status",
    "managed:rustup:install": "node scripts/install-managed-rustup.mjs install",
    "managed:rustup:status": "node scripts/install-managed-rustup.mjs status"
  },
  "dependencies": {
    "@ast-grep/cli": "0.42.1",
    "@biomejs/biome": "2.4.14",
    "@vue/language-server": "3.2.8",
    "bash-language-server": "5.6.0",
    "dockerfile-language-server-nodejs": "0.15.0",
    "eslint": "10.3.0",
    "opencode-ai": "1.14.39",
    "pnpm": "10.33.4",
    "prettier": "3.8.3",
    "pyright": "1.1.409",
    "svelte-language-server": "0.18.0",
    "typescript": "6.0.3",
    "typescript-language-server": "5.1.3",
    "vscode-langservers-extracted": "4.10.0",
    "yaml-language-server": "1.22.0"
  }
}
